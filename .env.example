# Autonomous Artist - Environment Configuration
# Copy this file to .env and fill in your values

# ======================
# Core API Settings
# ======================

# Hugging Face API Token (Required for AI features)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_TOKEN=your_huggingface_token_here

# ======================
# Application Settings
# ======================

# Flask application settings
DEBUG=False
HOST=0.0.0.0
PORT=5001

# Artist name
ARTIST_NAME=Aria

# ======================
# AI Model Configuration
# ======================

# Image generation models
IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
IMAGE_FALLBACK_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Text generation model
TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct
TEXT_MAX_TOKENS=150

# ======================
# API Settings
# ======================

# API timeouts and retries
API_TIMEOUT=120
API_MAX_RETRIES=3
API_RETRY_DELAY=1.0
API_RETRY_BACKOFF=2.0

# ======================
# Memory & Storage
# ======================

# Where to store artist memory
MEMORY_FILE=artist_memory.json

# Memory limits (prevents unbounded growth)
MAX_PORTFOLIO_SIZE=50
MAX_THEMES_TRACKED=100
MAX_COLORS_TRACKED=20
MAX_MOOD_HISTORY=10

# ======================
# Caching Settings
# ======================

# Enable response caching to save API costs and improve speed
CACHE_ENABLED=True

# Cache TTL for images (seconds) - default 7 days
CACHE_TTL_IMAGES=604800

# Cache TTL for text generation (seconds) - default 1 hour
CACHE_TTL_TEXT=3600

# ======================
# Artist Behavior
# ======================

# Probability of mood changes (0.0 - 1.0)
MOOD_SHIFT_PROBABILITY=0.6

# Chance of wildcard exploration (0.0 - 1.0)
WILDCARD_EXPLORATION_CHANCE=0.15

# How fast the artist learns from feedback (0.0 - 1.0)
LEARNING_RATE=0.08

# Satisfaction thresholds
HIGH_SATISFACTION_THRESHOLD=0.75
LOW_SATISFACTION_THRESHOLD=0.35

# ======================
# Social Media Integration
# ======================

# Facebook Page Integration (Optional)
# Get your Page Access Token from: https://developers.facebook.com/tools/explorer/
FB_PAGE_ID=your_facebook_page_id
FB_PAGE_ACCESS_TOKEN=your_page_access_token
FB_API_VERSION=v19.0

# Imgur Integration (Optional - for image hosting)
# Default uses anonymous upload, or get your own at: https://api.imgur.com/oauth2/addclient
IMGUR_CLIENT_ID=546c25a59c58ad7

# ======================
# Logging Configuration
# ======================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable/disable logging outputs
LOG_TO_FILE=True
LOG_TO_CONSOLE=True
# ======================
# Monitoring & Observability
# ======================

# Enable OpenTelemetry monitoring (requires: pip install opentelemetry-api opentelemetry-sdk)
MONITORING_ENABLED=False

# OpenTelemetry collector endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# Service name for traces
OTEL_SERVICE_NAME=autonomous-artist

# ======================
# Deployment Configuration
# ======================

# CORS allowed origins (comma-separated for multiple)
CORS_ORIGINS=*

# Rate limiting enabled
RATE_LIMIT_ENABLED=True

# Environment (development, production, staging)
FLASK_ENV=production